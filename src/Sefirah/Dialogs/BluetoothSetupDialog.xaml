<ContentDialog
    x:Class="Sefirah.Dialogs.BluetoothSetupDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Sefirah.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    PrimaryButtonText=""
    SecondaryButtonText=""
    CloseButtonText=""
    Style="{ThemeResource DefaultContentDialogStyle}">

    <ContentDialog.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" Inverse="True" />
        <x:Double x:Key="ContentDialogMaxWidth">560</x:Double>
        <Thickness x:Key="ContentDialogPadding">0</Thickness>
    </ContentDialog.Resources>

    <Grid x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title bar  -->
        <Button
            Grid.Row="0"
            Margin="4,0"
            x:Name="CloseDialogButton"
            Width="36"
            Height="36"
            HorizontalAlignment="Right"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderBrush="Transparent"
            Click="CloseDialogButton_Click">
            <FontIcon FontSize="12" Glyph="&#xE8BB;" />
        </Button>

        <!--  Content  -->
        <Grid Grid.Row="1" Padding="24,20,24,24" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"  />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  State panels (layered)  -->
            <Grid Grid.Row="0" HorizontalAlignment="Center">
                <StackPanel
                    Spacing="10"
                    Visibility="{x:Bind ViewModel.ShowIntroPanel, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        Text="We will ask your phone to allow Bluetooth discovery, then match it on this PC."
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Border
                        Padding="12,10"
                        CornerRadius="{ThemeResource ControlCornerRadius}"
                        Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                        BorderBrush="{ThemeResource SystemFillColorCautionBrush}"
                        BorderThickness="1"
                        Visibility="{x:Bind ViewModel.ShowPhonePermissionRetry, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock
                            Text="Bluetooth discovery failed. Unlock and allow Bluetooth discovery on your phone when prompted."
                            TextWrapping="Wrap"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    </Border>
                </StackPanel>

                <StackPanel
                    Spacing="12"
                    Visibility="{x:Bind ViewModel.ShowWaitingPhonePanel, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressRing Width="36" Height="36" IsActive="True" HorizontalAlignment="Center" />
                    <TextBlock
                        Text="Check your device"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    <TextBlock
                        Text="You may be asked to turn on Bluetooth permissions on your device."
                        TextWrapping="Wrap"
                        TextAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <StackPanel
                    Spacing="12"
                    Visibility="{x:Bind ViewModel.ShowScanningPanel, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressRing Width="36" Height="36" IsActive="True" HorizontalAlignment="Center" />
                    <TextBlock
                        Text="Looking for your phone…"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <StackPanel
                    Spacing="8"
                    Visibility="{x:Bind ViewModel.ShowBluetoothOffMessage, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        Text="Bluetooth turned off. Please enable Bluetooth and try again."
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <StackPanel
                    Spacing="8"
                    Visibility="{x:Bind ViewModel.ShowDeviceNotFoundMessage, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        Text="No matching Bluetooth device appeared. Put the phone in pairing mode and try again."
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <StackPanel
                    Spacing="8"
                    Visibility="{x:Bind ViewModel.ShowPairingFailedMessage, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock
                        Text="Pairing did not complete. Try again."
                        TextWrapping="Wrap"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <ProgressRing Width="36" Height="36" IsActive="True" HorizontalAlignment="Center" Visibility="{x:Bind ViewModel.ShowPairingPanel, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!--  Inline PIN confirmation  -->
                <StackPanel
                    Spacing="16"
                    HorizontalAlignment="Center"
                    Visibility="{x:Bind ViewModel.ShowInlinePairingPanel, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center">
                        <Run Text="Does the PIN on " />
                        <Run FontWeight="SemiBold" Text="{x:Bind ViewModel.InlinePairingDeviceName, Mode=OneWay}" />
                        <Run Text=" match the PIN below?" />
                    </TextBlock>
                    <TextBlock
                        Text="{x:Bind ViewModel.InlinePairingCode, Mode=OneWay}"
                        FontSize="36"
                        FontWeight="SemiBold"
                        FontFamily="Consolas"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                        <Button Content="No" Command="{x:Bind ViewModel.DeclineInlinePairingCommand, Mode=OneWay}" />
                        <Button
                            Content="Yes"
                            Style="{ThemeResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.ConfirmInlinePairingCommand, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <!--  Footer  -->
            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="8"
                Visibility="{x:Bind ViewModel.ShowDialogFooter, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Button
                    Content="Continue"
                    Style="{ThemeResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.StartSetupCommand, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.ShowIntroPanel, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <Button
                    Content="Try again"
                    Style="{ThemeResource AccentButtonStyle}"
                    Command="{x:Bind ViewModel.StartSetupCommand, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.ShowNoDevicesPanel, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
    </Grid>
</ContentDialog>
