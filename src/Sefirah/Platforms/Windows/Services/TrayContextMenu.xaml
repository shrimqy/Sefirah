<local:DesktopMenuFlyout
    x:Class="Sefirah.Platforms.Windows.Services.TrayContextMenu"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DesktopFlyouts"
    xmlns:helpers="using:Sefirah.Helpers">

    <MenuFlyoutItem x:Name="ShowHideItem" Text="{helpers:ResourceString Name=ShowHideWindow}" />
    <MenuFlyoutSeparator />
    <MenuFlyoutItem x:Name="ExitItem" Text="{helpers:ResourceString Name=Exit}" />

</local:DesktopMenuFlyout>
