<Project Sdk="Uno.Sdk">
    <PropertyGroup>
        <TargetFrameworks>net10.0-windows10.0.26100;net10.0-desktop</TargetFrameworks>

        <OutputType>Exe</OutputType>
        <UnoSingleProject>true</UnoSingleProject>

        <!-- Display name -->
        <ApplicationTitle>Sefirah</ApplicationTitle>
        <!-- App Identifier -->
        <ApplicationId>com.sefirah.castle</ApplicationId>
        <!-- Versions -->
        <ApplicationDisplayVersion>2.4.0</ApplicationDisplayVersion>
        <ApplicationVersion>8</ApplicationVersion>
        <!-- Package Publisher -->
        <ApplicationPublisher>shrimqy</ApplicationPublisher>
        <!-- Package Description -->
        <Description>Sefirah powered by Uno Platform.</Description>
        <!--
            If you encounter this error message:

            error NETSDK1148: A referenced assembly was compiled using a newer version of Microsoft.Windows.SDK.NET.dll.
            Please update to a newer .NET SDK in order to reference this assembly.

            This means that the two packages below must be aligned with the "build" version number of
            the "Microsoft.Windows.SDK.BuildTools" package above, and the "revision" version number
            must be the highest found in https://www.nuget.org/packages/Microsoft.Windows.SDK.NET.Ref.
        -->
        <!-- <WindowsSdkPackageVersion>10.0.22621.28</WindowsSdkPackageVersion> -->

        <!--
            UnoFeatures let's you quickly add and manage implicit package references based on the features you want to use.
            https://aka.platform.uno/singleproject-features
        -->
        <UnoFeatures>
            Lottie;
            Hosting;
            Toolkit;
            Logging;
            LoggingSerilog;
            Mvvm;
            Configuration;
            Localization;
            ThemeService;
            SkiaRenderer;
        </UnoFeatures>
        <Platforms>x64;ARM64</Platforms>
        <LangVersion>Preview</LangVersion>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    </PropertyGroup>


    <PropertyGroup Condition="'$(UapAppxPackageBuildMode)' == 'StoreUpload'">
        <GenerateTemporaryStoreCertificate>True</GenerateTemporaryStoreCertificate>
    </PropertyGroup>

    <PropertyGroup Condition="'$(UapAppxPackageBuildMode)' == 'Sideloading'">
        <GenerateTemporaryStoreCertificate>False</GenerateTemporaryStoreCertificate>
        <AppxPackageSigningEnabled>True</AppxPackageSigningEnabled>
        <PackageCertificateKeyFile>Sefirah_TemporaryKey.pfx</PackageCertificateKeyFile>
        <PackageCertificateThumbprint>276047138A50F9695B57C0E0763E5A414C03B049</PackageCertificateThumbprint>
    </PropertyGroup>

    <PropertyGroup>
        <UnoIconForegroundFile>Assets\Icons\icon_foreground.svg</UnoIconForegroundFile>
        <UnoIconBackgroundColor Condition="'$(IsWinAppSdk)' == 'true'">Transparent</UnoIconBackgroundColor>
    </PropertyGroup>

    <PropertyGroup Condition="'$(TargetFramework)' == 'net10.0-windows10.0.26100'">
        <StartupObject>Sefirah.Platforms.Windows.Program</StartupObject>
        <TargetPlatformMinVersion>10.0.19041.0</TargetPlatformMinVersion>
    </PropertyGroup>
    <PropertyGroup Condition="'$(TargetFramework)' == 'net10.0-desktop'">
        <StartupObject>Program</StartupObject>
    </PropertyGroup>

    <ItemGroup Condition="'$(TargetFramework)' == 'net10.0-desktop'">
        <PackageReference Include="Tmds.DBus.Protocol" />
        <PackageReference Include="Tmds.DBus.Generator">
            <PrivateAssets>all</PrivateAssets>
            <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
        </PackageReference>
        <AdditionalFiles Include="Platforms\Desktop\Tray\DBusXml\com.canonical.dbusmenu.xml" Namespace="Sefirah.Platforms.Desktop.Tray.DBus" DBusGeneratorMode="Handler" />
        <AdditionalFiles Include="Platforms\Desktop\Tray\DBusXml\org.kde.StatusNotifierItem.xml" Namespace="Sefirah.Platforms.Desktop.Tray.DBus" DBusGeneratorMode="Handler" />
        <AdditionalFiles Include="Platforms\Desktop\Tray\DBusXml\org.kde.StatusNotifierWatcher.xml" Namespace="Sefirah.Platforms.Desktop.Tray.DBus" DBusGeneratorMode="Proxy" />
    </ItemGroup>

    <PropertyGroup Condition="'$(TargetFramework)' == 'net10.0-windows10.0.26100'">
        <PublishTrimmed>false</PublishTrimmed>
        <TrimMode>partial</TrimMode>
        <!-- Disable ILLink  -->
        <RunILLink>false</RunILLink>
        <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
        <JsonSerializerIsReflectionEnabledByDefault>true</JsonSerializerIsReflectionEnabledByDefault>
    </PropertyGroup>

    <ItemGroup Condition="'$(TargetFramework)' == 'net10.0-windows10.0.26100'">
        <PackageReference Include="DesktopFlyouts.WinUI" />
        <RuntimeHostConfigurationOption Include="System.Runtime.InteropServices.BuiltInComInterop.IsSupported" Value="true" />
        <RuntimeHostConfigurationOption Include="System.Runtime.Serialization.EnableUnsafeBinaryFormatterSerialization" Value="false" />
    </ItemGroup>

    <ItemGroup>
        <Content Include="Assets\Icons\IconResource.dll">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <Content Include="Assets\Icons\SefirahDark.ico">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
        <Content Include="Assets\Icons\SefirahLight.ico">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </Content>
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="AdvancedSharpAdbClient" />
        <PackageReference Include="BouncyCastle.Cryptography" />
        <PackageReference Include="CommunityToolkit.WinUI.Controls.SettingsControls" />
        <PackageReference Include="CommunityToolkit.WinUI.Converters" />
        <PackageReference Include="CommunityToolkit.WinUI.Extensions" />
        <PackageReference Include="CommunityToolkit.WinUI.Controls.Segmented" />
        <PackageReference Include="libphonenumber-csharp" />
        <PackageReference Include="MeaMod.DNS" />
        <PackageReference Include="NAudio" />
        <PackageReference Include="NetCoreServer" />
        <PackageReference Include="sqlite-net-pcl" />
        <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" />
        <PackageReference Include="SSH.NET" />
        <PackageReference Include="Tmds.DBus" />
        <PackageReference Include="Vanara.PInvoke.CldApi" />
        <PackageReference Include="Vanara.PInvoke.Ole" />
        <PackageReference Include="Vanara.PInvoke.Shell32" />
        <PackageReference Include="QRCoder" />
    </ItemGroup>
    
    <ItemGroup Condition="'$(TargetFramework)' == 'net10.0-windows10.0.26100'">
        <PackageReference Include="Microsoft.Windows.SDK.BuildTools" VersionOverride="10.0.28000.1839" />
        <PackageReference Include="Microsoft.WindowsAppSDK" />
    </ItemGroup>

    <ItemGroup>
        <UnoSplashScreen Update="Assets\Splash\splash_screen.svg">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </UnoSplashScreen>
    </ItemGroup>

    <!-- Hosted app PRI generation: bundle Windows SDK mrmsupport.dll into the MSIX package. -->
    <PropertyGroup Condition="'$(TargetFramework)' == 'net10.0-windows10.0.26100'">
        <SefirahMrmSupportSdkVersion Condition="'$(SefirahMrmSupportSdkVersion)' == ''">10.0.26100.0</SefirahMrmSupportSdkVersion>
        <SefirahMrmSupportSdkArch Condition="'$(Platform)' == 'ARM64'">arm64</SefirahMrmSupportSdkArch>
        <SefirahMrmSupportSdkArch Condition="'$(SefirahMrmSupportSdkArch)' == ''">x64</SefirahMrmSupportSdkArch>
    </PropertyGroup>
    <PropertyGroup Condition="'$(TargetFramework)' == 'net10.0-windows10.0.26100' and '$(SefirahMrmSupportDll)' == '' and Exists('C:\Program Files (x86)\Windows Kits\10\bin\$(SefirahMrmSupportSdkVersion)\$(SefirahMrmSupportSdkArch)\mrmsupport.dll')">
        <SefirahMrmSupportDll>C:\Program Files (x86)\Windows Kits\10\bin\$(SefirahMrmSupportSdkVersion)\$(SefirahMrmSupportSdkArch)\mrmsupport.dll</SefirahMrmSupportDll>
    </PropertyGroup>
    <PropertyGroup Condition="'$(TargetFramework)' == 'net10.0-windows10.0.26100' and '$(SefirahMrmSupportDll)' == '' and Exists('C:\Program Files\Windows Kits\10\bin\$(SefirahMrmSupportSdkVersion)\$(SefirahMrmSupportSdkArch)\mrmsupport.dll')">
        <SefirahMrmSupportDll>C:\Program Files\Windows Kits\10\bin\$(SefirahMrmSupportSdkVersion)\$(SefirahMrmSupportSdkArch)\mrmsupport.dll</SefirahMrmSupportDll>
    </PropertyGroup>
    <Target Name="IncludeMrmSupportDll" BeforeTargets="PrepareForBuild" Condition="'$(TargetFramework)' == 'net10.0-windows10.0.26100' and '$(Platform)' != 'Any CPU'">
        <Error Condition="'$(SefirahMrmSupportDll)' == '' or !Exists('$(SefirahMrmSupportDll)')" Text="Windows SDK mrmsupport.dll was not found. Install the Windows SDK or set SefirahMrmSupportDll." />
        <ItemGroup>
            <Content Include="$(SefirahMrmSupportDll)">
                <Link>mrmsupport.dll</Link>
                <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            </Content>
        </ItemGroup>
    </Target>
</Project>
