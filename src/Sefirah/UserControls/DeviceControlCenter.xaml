<UserControl
    x:Class="Sefirah.UserControls.DeviceControlCenter"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Sefirah.Converters"
    xmlns:helpers="using:Sefirah.Helpers"
    xmlns:messages="using:Sefirah.Data.Models.Messages"
    xmlns:models="using:Sefirah.Data.Models"
    xmlns:utu="using:Uno.Toolkit.UI"
    xmlns:wuc="using:CommunityToolkit.WinUI.Controls"
    xmlns:wctconverters="using:CommunityToolkit.WinUI.Converters">

    <UserControl.Resources>
            <converters:EmptyObjectToVisibilityConverter x:Key="EmptyObjectToVisibilityConverter" />
            <converters:BatteryStatusToIconConverter x:Key="BatteryStatusToIconConverter" />
            <converters:RingerModeToIconConverter x:Key="RingerModeToIconConverter" />
            <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:BooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" Inverse="True" />
            <wctconverters:BoolToObjectConverter
                x:Key="BoolToDndButtonStyleConverter"
                FalseValue="{StaticResource DefaultButtonStyle}"
                TrueValue="{StaticResource AccentButtonStyle}" />
            <wctconverters:BoolToObjectConverter x:Key="BoolToConnectedOpacityConverter" FalseValue="0.4" TrueValue="1.0" />
            <wctconverters:EmptyObjectToObjectConverter
                x:Key="EmptyObjectToOpacityConverter"
                EmptyValue="1.0"
                NotEmptyValue="0.0" />

            <Style x:Key="ConnectionSplitButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
                <Setter Property="Height" Value="32" />
                <Setter Property="MinWidth" Value="32" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="VerticalContentAlignment" Value="Center" />
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
            </Style>

            <Storyboard x:Key="FadeInAnimation" x:Name="FadeInStoryboard">
                <DoubleAnimation
                    Storyboard.TargetName="PhoneFrameOverlay"
                    Storyboard.TargetProperty="Opacity"
                    From="0"
                    To="1"
                    Duration="0:0:0.200" />
            </Storyboard>
            <Storyboard x:Key="FadeOutAnimation" x:Name="FadeOutStoryboard">
                <DoubleAnimation
                    Storyboard.TargetName="PhoneFrameOverlay"
                    Storyboard.TargetProperty="Opacity"
                    From="1"
                    To="0"
                    Duration="0:0:0.200" />
            </Storyboard>
    </UserControl.Resources>

    <Grid>
        <Grid RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid
                x:Name="PhoneFrameGrid"
                Grid.Column="0"
                Width="54"
                Height="100"
                VerticalAlignment="Center"
                CornerRadius="8"
                PointerEntered="PhoneFrame_PointerEntered"
                PointerExited="PhoneFrame_PointerExited"
                PointerWheelChanged="PhoneFrame_PointerWheelChanged">
                <Rectangle
                    Opacity="0.5"
                    RadiusX="4"
                    RadiusY="4"
                    Stroke="Black"
                    StrokeThickness="2">
                    <Rectangle.Fill>
                        <SolidColorBrush Opacity="0.1" Color="{ThemeResource SystemBaseLowColor}" />
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle
                    Margin="2"
                    RadiusX="4"
                    RadiusY="4"
                    Stroke="Black"
                    StrokeThickness="1" />
                <Border Margin="3" CornerRadius="4">
                    <Border.Background>
                        <LinearGradientBrush Opacity="{x:Bind ViewModel.Device.Wallpaper, Converter={StaticResource EmptyObjectToOpacityConverter}, Mode=OneWay}" StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0" Color="#FF0070FF" />
                            <GradientStop Offset="1" Color="#FF2E90FF" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Image
                        Source="{x:Bind ViewModel.Device.Wallpaper, Mode=OneWay}"
                        Stretch="UniformToFill"
                        Visibility="{x:Bind ViewModel.Device.Wallpaper, Mode=OneWay, Converter={StaticResource EmptyObjectToVisibilityConverter}}" />
                </Border>
                <Grid
                    x:Name="PhoneFrameOverlay"
                    AutomationProperties.Name="{helpers:ResourceString Name=StartScreenMirroring}"
                    Background="#80000000"
                    Opacity="0"
                    utu:CommandExtensions.Command="{x:Bind ViewModel.StartScrcpyCommand}"
                    Visibility="Collapsed">
                    <FontIcon
                        Foreground="White"
                        Glyph="&#xEC15;"
                        Visibility="{x:Bind ViewModel.LoadingScrcpy, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                    <ToolTipService.ToolTip>
                        <ToolTip Content="Screen Mirror" />
                    </ToolTipService.ToolTip>
                </Grid>
                <Grid Visibility="{x:Bind ViewModel.LoadingScrcpy, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ProgressRing
                        Width="24"
                        Height="24"
                        Foreground="White"
                        IsActive="{x:Bind ViewModel.LoadingScrcpy, Mode=OneWay}" />
                </Grid>
            </Grid>

            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="4">
                <TextBlock
                    FontWeight="SemiBold"
                    Text="{x:Bind ViewModel.Device.Name, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.Device.Name, Mode=OneWay, Converter={StaticResource EmptyObjectToVisibilityConverter}}" />

                <StackPanel Orientation="Horizontal" Spacing="4">
                    <Button
                        x:Name="AudioButton"
                        Padding="4"
                        AutomationProperties.Name="{helpers:ResourceString Name=DeviceAudio}"
                        Background="Transparent"
                        BorderThickness="0">
                        <FontIcon
                            Glyph="{x:Bind ViewModel.Device.RingerMode, Converter={StaticResource RingerModeToIconConverter}, Mode=OneWay}"
                            Opacity="{x:Bind ViewModel.Device.IsConnected, Mode=OneWay, Converter={StaticResource BoolToConnectedOpacityConverter}}" />
                        <Button.Flyout>
                            <Flyout
                                x:Name="AudioFlyout"
                                Opened="PaneFlyout_Opened"
                                Placement="{x:Bind PaneFlyoutPlacement, Mode=OneWay}"
                                ShouldConstrainToRootBounds="False">
                                <Flyout.FlyoutPresenterStyle>
                                    <Style BasedOn="{StaticResource DefaultFlyoutPresenterStyle}" TargetType="FlyoutPresenter">
                                        <Setter Property="MinWidth" Value="280" />
                                    </Style>
                                </Flyout.FlyoutPresenterStyle>
                                <Grid RowSpacing="12">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <ItemsRepeater Grid.Row="0" HorizontalAlignment="Stretch" ItemsSource="{x:Bind ViewModel.Device.Streams, Mode=OneWay}">
                                        <ItemsRepeater.Layout>
                                            <UniformGridLayout
                                                ItemsStretch="Fill"
                                                MinItemWidth="64"
                                                Orientation="Horizontal" />
                                        </ItemsRepeater.Layout>
                                        <ItemsRepeater.ItemTemplate>
                                            <DataTemplate x:DataType="models:AudioStream">
                                                <StackPanel HorizontalAlignment="Stretch" Spacing="8">
                                                    <FontIcon Glyph="{x:Bind IconGlyph}" />
                                                    <Slider
                                                        HorizontalAlignment="Center"
                                                        Height="120"
                                                        Maximum="100"
                                                        Minimum="0"
                                                        Orientation="Vertical"
                                                        PointerCaptureLost="AudioSlider_PointerCaptureLost"
                                                        Tag="{x:Bind}"
                                                        Value="{x:Bind Level, Mode=TwoWay}" />
                                                    <TextBlock
                                                        HorizontalAlignment="Stretch"
                                                        FontSize="12"
                                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                        Text="{x:Bind Label}"
                                                        TextAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsRepeater.ItemTemplate>
                                    </ItemsRepeater>
                                    <wuc:Segmented Grid.Row="1" HorizontalAlignment="Stretch" SelectedIndex="{x:Bind ViewModel.Device.RingerMode, Mode=OneWay}" SelectionChanged="RingerModeSegmented_SelectionChanged">
                                        <wuc:SegmentedItem Content="{helpers:ResourceString Name=AudioSilent}">
                                            <wuc:SegmentedItem.Icon>
                                                <FontIcon Glyph="&#xE7ED;" />
                                            </wuc:SegmentedItem.Icon>
                                        </wuc:SegmentedItem>
                                        <wuc:SegmentedItem Content="{helpers:ResourceString Name=AudioVibrate}">
                                            <wuc:SegmentedItem.Icon>
                                                <FontIcon Glyph="&#xE877;" />
                                            </wuc:SegmentedItem.Icon>
                                        </wuc:SegmentedItem>
                                        <wuc:SegmentedItem Content="{helpers:ResourceString Name=AudioRing}">
                                            <wuc:SegmentedItem.Icon>
                                                <FontIcon Glyph="&#xEA8F;" />
                                            </wuc:SegmentedItem.Icon>
                                        </wuc:SegmentedItem>
                                    </wuc:Segmented>
                                </Grid>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <StackPanel
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Opacity="{x:Bind ViewModel.Device.IsConnected, Mode=OneWay, Converter={StaticResource BoolToConnectedOpacityConverter}}"
                        Spacing="1">
                        <FontIcon Margin="0,0,4,0" Glyph="{x:Bind ViewModel.Device.BatteryStatus, Converter={StaticResource BatteryStatusToIconConverter}, Mode=OneWay}" />
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.Device.BatteryStatus.BatteryLevel, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.Device.BatteryStatus, Mode=OneWay, Converter={StaticResource EmptyObjectToVisibilityConverter}}" />
                        <TextBlock
                            FontWeight="SemiBold"
                            Text="%"
                            Visibility="{x:Bind ViewModel.Device.BatteryStatus, Mode=OneWay, Converter={StaticResource EmptyObjectToVisibilityConverter}}" />
                    </StackPanel>
                </StackPanel>

                <Grid
                    HorizontalAlignment="Left"
                    Visibility="{x:Bind ViewModel.Device.Name, Mode=OneWay, Converter={StaticResource EmptyObjectToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button
                        x:Name="ConnectionStatusButton"
                        Grid.Column="0"
                        Padding="12,0,12,0"
                        BorderThickness="1,1,0,1"
                        CornerRadius="4,0,0,4"
                        Style="{StaticResource ConnectionSplitButtonStyle}">
                        <TextBlock Text="{x:Bind ViewModel.Device.ConnectionStatusText, Mode=OneWay}" />

                        <Button.Flyout>
                            <Flyout
                                x:Name="ConnectionFlyout"
                                Opened="PaneFlyout_Opened"
                                Placement="{x:Bind PaneFlyoutPlacement, Mode=OneWay}"
                                ShouldConstrainToRootBounds="False">
                                <Flyout.FlyoutPresenterStyle>
                                    <Style BasedOn="{StaticResource DefaultFlyoutPresenterStyle}" TargetType="FlyoutPresenter">
                                        <Setter Property="MinWidth" Value="354" />
                                    </Style>
                                </Flyout.FlyoutPresenterStyle>

                                <StackPanel Spacing="8">
                                    <ListView
                                        ItemsSource="{x:Bind ViewModel.Device.ConnectedAdbDevices, Mode=OneWay}"
                                        SelectionMode="None"
                                        ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="models:AdbDevice">
                                                <Grid Padding="12,8" ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <FontIcon
                                                        Grid.Column="0"
                                                        VerticalAlignment="Center"
                                                        Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                        Glyph="{x:Bind TypeIconGlyph, Mode=OneWay}" />
                                                    <TextBlock
                                                        Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Text="{x:Bind DisplayName, Mode=OneWay}" />
                                                    <Button
                                                        Grid.Column="2"
                                                        Padding="8,8"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Click="DisconnectAdbDeviceButton_Click"
                                                        Tag="{x:Bind}"
                                                        ToolTipService.ToolTip="{helpers:ResourceString Name=Disconnect}"
                                                        Visibility="{x:Bind CanDisconnect, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                        <FontIcon FontSize="12" Glyph="&#xE711;" />
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <TextBlock
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{helpers:ResourceString Name=AdbNoDevice}"
                                        HorizontalAlignment="Center"
                                        Visibility="{x:Bind ViewModel.Device.HasAdbConnection, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>

                                    <Rectangle Height="1" Fill="{ThemeResource ControlStrokeColorDefaultBrush}" />

                                    <ListView
                                        IsItemClickEnabled="True"
                                        ItemClick="AddressListView_ItemClick"
                                        ItemsSource="{x:Bind ViewModel.Device.Addresses, Mode=OneWay}"
                                        SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="messages:AddressEntry">
                                                <StackPanel Orientation="Horizontal" Spacing="8" Padding="12,8">
                                                    <Grid VerticalAlignment="Center">
                                                        <FontIcon
                                                            Glyph="&#xE95A;"
                                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                            Visibility="{x:Bind IsConnected, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                                                        <FontIcon
                                                            Glyph="&#xE95A;"
                                                            Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                            Visibility="{x:Bind IsConnected, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                    </Grid>
                                                    <TextBlock VerticalAlignment="Center" Text="{x:Bind Address, Mode=OneWay}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <Button
                                        HorizontalAlignment="Stretch"
                                        Click="DisconnectButton_Click"
                                        Visibility="{x:Bind ViewModel.Device.IsConnected, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{helpers:ResourceString Name=Disconnect}" />
                                    </Button>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>

                    <Button
                        x:Name="RefreshConnectionButton"
                        Grid.Column="1"
                        Padding="0"
                        Command="{x:Bind ViewModel.RefreshConnectionCommand}"
                        CornerRadius="0,4,4,0"
                        Style="{StaticResource ConnectionSplitButtonStyle}">
                        <Grid Width="16" Height="16">
                            <FontIcon
                                FontSize="14"
                                Glyph="&#xE895;"
                                Visibility="{x:Bind ViewModel.Device.IsConnecting, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                            <ProgressRing
                                Width="16"
                                Height="16"
                                IsActive="{x:Bind ViewModel.Device.IsConnecting, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.Device.IsConnecting, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Padding="8,4"
                AutomationProperties.Name="{helpers:ResourceString Name=DndToggle}"
                Command="{x:Bind ViewModel.ToggleDndCommand}"
                Style="{x:Bind ViewModel.Device.DndEnabled, Converter={StaticResource BoolToDndButtonStyleConverter}, Mode=OneWay}">
                <FontIcon Glyph="&#xECE4;" />
            </Button>
            <Button
                Grid.Column="1"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Padding="8,4"
                AutomationProperties.Name="{helpers:ResourceString Name=ShareFiles}"
                Click="SendFilesButton_Click">
                <FontIcon Glyph="&#xE72D;" />
            </Button>
            <Button
                Grid.Column="2"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"
                Padding="8,4"
                AutomationProperties.Name="{helpers:ResourceString Name=DeviceSettings}"
                Command="{x:Bind ViewModel.OpenDeviceSettingsCommand}">
                <FontIcon Glyph="&#xE713;" />
            </Button>
        </Grid>
        </Grid>

        <TeachingTip
            x:Name="PhoneFrameScrollTeachingTip"
            Closed="PhoneFrameScrollTeachingTip_Closed"
            IsLightDismissEnabled="True"
            PreferredPlacement="Right"
            Subtitle="{helpers:ResourceString Name=PhoneFrameScrollTip}"
            Target="{x:Bind PhoneFrameGrid}"
            Title="Switch devices" />
    </Grid>
</UserControl>
