<Page
    x:Class="Sefirah.Views.CallsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:Sefirah.Helpers"
    xmlns:converters="using:Sefirah.Converters"
    xmlns:wctconverters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Sefirah.Data.Models"
    xmlns:messagesModel="using:Sefirah.Data.Models.Messages"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:BooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" Inverse="True" />
        <converters:EmptyObjectToVisibilityConverter x:Key="EmptyObjectToVisibilityConverter" />
        <converters:EmptyObjectToVisibilityConverter x:Key="InverseEmptyObjectToVisibilityConverter" Inverse="True" />
        <wctconverters:EmptyStringToObjectConverter x:Key="EmptyStringToObjectConverter" EmptyValue="False" NotEmptyValue="True" />
        <wctconverters:StringVisibilityConverter x:Key="StringVisibilityConverter" />
        <wctconverters:StringVisibilityConverter x:Key="InverseStringVisibilityConverter" EmptyValue="Visible" NotEmptyValue="Collapsed" />

        <Style x:Key="DialPadKeyStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="MinHeight" Value="52"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiLight"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Call history -->
        <Grid Grid.Column="0" RowSpacing="8" BorderBrush="{ThemeResource CardStrokeColorDefault}" BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock
                Text="Calls"
                FontSize="24"
                FontWeight="SemiBold"
                Margin="16,16,0,0"/>

            <Grid Grid.Row="1"> 
                <ProgressRing
                    IsActive="{x:Bind ViewModel.IsLoadingCallLogs, Mode=OneWay}"
                    Width="28"
                    Height="28" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Text="{helpers:ResourceString Name=CallLogDisabled/Description}"
                    TextWrapping="Wrap"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondary}"
                    Visibility="{x:Bind ViewModel.ShowCallLogEmpty, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <ListView
                    x:Name="CallLogsListView"
                    ItemsSource="{x:Bind ViewModel.CallLogs, Mode=OneWay}"
                    SelectionMode="None"
                    IsItemClickEnabled="True"
                    ItemClick="CallLogs_ItemClick"
                    Visibility="{x:Bind ViewModel.ShowCallLogList, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:CallLog">
                            <Grid Padding="4,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid
                                    Grid.Column="0"
                                    Width="40"
                                    Height="40"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center">
                                    <PersonPicture
                                        Width="40"
                                        Height="40"
                                        DisplayName="{x:Bind PrimaryLabel, Mode=OneWay}"
                                        ProfilePicture="{x:Bind AvatarImage, Mode=OneWay}"
                                        Visibility="{x:Bind AvatarImage, Mode=OneWay, Converter={StaticResource EmptyObjectToVisibilityConverter}}" />
                                    <Border
                                        Width="40"
                                        Height="40"
                                        CornerRadius="20"
                                        DataContextChanged="CallAvatarBorder_DataContextChanged"
                                        BorderThickness="1"
                                        Visibility="{x:Bind AvatarImage, Mode=OneWay, Converter={StaticResource InverseEmptyObjectToVisibilityConverter}}">
                                        <FontIcon
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="18"
                                            Glyph="&#xE77B;" />
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{x:Bind PrimaryLabel, Mode=OneWay}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock
                                        FontSize="12"
                                        Opacity="0.7"
                                        Text="{x:Bind CallTypeAndDuration, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="2"
                                    Margin="12,0,0,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        FontSize="12"
                                        Opacity="0.7"
                                        Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                        Text="{x:Bind FormattedWhen, Mode=OneWay}" />
                                    <Button
                                        Width="36"
                                        Height="36"
                                        CornerRadius="18"
                                        Click="CallLogItemCallButton_Click"
                                        Tag="{x:Bind}"
                                        Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <FontIcon Glyph="&#xE717;" FontSize="14"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>

        <!-- Call panel -->
        <Grid Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock
                Text="{helpers:ResourceString Name=BluetoothCallingUnsupported}"
                TextWrapping="Wrap"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="360"
                TextAlignment="Center"
                Opacity="0.75"
                Visibility="{x:Bind ViewModel.ShowCallingUnsupportedPanel, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            
            <StackPanel
                VerticalAlignment="Center"
                Spacing="20"
                Visibility="{x:Bind ViewModel.ShowBluetoothAdapterNotFoundPanel, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <FontIcon Glyph="&#xE702;" FontSize="26"/>
                <TextBlock
                    Text="{helpers:ResourceString Name=BluetoothCallingUnavailable/Title}"
                    FontSize="22"
                    FontWeight="SemiBold"
                    TextAlignment="Center"
                    TextWrapping="Wrap"/>
                <TextBlock
                    Text="{helpers:ResourceString Name=BluetoothCallingUnavailable/Description}"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondary}" />
            </StackPanel>

            <StackPanel
                VerticalAlignment="Center"
                Spacing="20"
                Visibility="{x:Bind ViewModel.ShowBluetoothEnablePanel, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <FontIcon Glyph="&#xE702;" FontSize="26"/>
                <TextBlock
                    Text="{helpers:ResourceString Name=BluetoothDisabled/Title}"
                    FontSize="22"
                    FontWeight="SemiBold"
                    TextAlignment="Center"
                    TextWrapping="Wrap"/>
                <TextBlock
                    Text="{helpers:ResourceString Name=BluetoothDisabled/Description}"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondary}" />
                <Button
                    Content="Turn on Bluetooth"
                    Click="EnableBluetoothButton_Click"
                    Style="{ThemeResource AccentButtonStyle}"
                    HorizontalAlignment="Center"
                    MinWidth="220"
                    Padding="16,10"/>
            </StackPanel>

            <StackPanel
                VerticalAlignment="Center"
                Spacing="20"
                Visibility="{x:Bind ViewModel.ShowBluetoothPairingPanel, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <FontIcon Glyph="&#xE702;" FontSize="26"/>
                <TextBlock
                    Text="{helpers:ResourceString Name=BluetoothPairing/Title}"
                    FontSize="22"
                    FontWeight="SemiBold"
                    TextAlignment="Center"
                    TextWrapping="Wrap"/>
                <TextBlock
                    Text="{helpers:ResourceString Name=BluetoothPairing/Description}"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondary}"/>
                <Button
                    Content="{helpers:ResourceString Name=BluetoothPairingAction}"
                    Command="{x:Bind ViewModel.BeginPairBluetoothCommand}"
                    Style="{ThemeResource AccentButtonStyle}"
                    HorizontalAlignment="Center"
                    MinWidth="200"
                    Padding="16,10"/>
            </StackPanel>

            <StackPanel
                VerticalAlignment="Center"
                Spacing="10"
                MaxWidth="360"
                Visibility="{x:Bind ViewModel.IsCallingSetupError, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">
                <FontIcon Glyph="&#xE783;" FontSize="26" HorizontalAlignment="Center"/>
                <TextBlock
                    Text="{helpers:ResourceString Name=BluetoothRegistrationFailed/Title}"
                    FontSize="20"
                    FontWeight="SemiBold"
                    TextAlignment="Center"/>
                <TextBlock
                    Text="{helpers:ResourceString Name=BluetoothRegistrationFailed/Description}"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    FontSize="13"
                    Foreground="{ThemeResource TextFillColorSecondary}" />
                <Button
                    Content="{helpers:ResourceString Name=TryAgain}"
                    Click="RetryCallingSetupButton_Click"
                    HorizontalAlignment="Center"
                    MinWidth="160"
                    Padding="14,8"/>
            </StackPanel>

            <Grid
                Margin="20"
                VerticalAlignment="Stretch"
                Visibility="{x:Bind ViewModel.ShowDialer, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}">

                <AutoSuggestBox
                    VerticalAlignment="Top" 
                    PlaceholderText="{helpers:ResourceString Name=SearchContacts}"
                    Text="{x:Bind ViewModel.ContactSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    ItemsSource="{x:Bind ViewModel.ContactSearchResults, Mode=OneWay}"
                    UpdateTextOnSelect="False"
                    TextChanged="ContactSearch_TextChanged"
                    QuerySubmitted="ContactSearch_QuerySubmitted"
                    SuggestionChosen="ContactSearch_SuggestionChosen">
                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate x:DataType="models:Contact">
                            <Grid Margin="0,8,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <PersonPicture
                                    Grid.Column="0"
                                    Width="40"
                                    Height="40"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    DisplayName="{x:Bind DisplayName}"
                                    ProfilePicture="{x:Bind Avatar}" />

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock
                                        MaxWidth="280"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind DisplayName, Mode=OneWay, FallbackValue='Unknown'}"
                                        TextTrimming="CharacterEllipsis" />
                                    <TextBlock
                                        MaxWidth="280"
                                        Margin="0,4,0,0"
                                        FontSize="12"
                                        Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                        Text="{x:Bind Address, Mode=OneWay}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                    <AutoSuggestBox.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="12,8" />
                            <Setter Property="MinHeight" Value="60" />
                        </Style>
                    </AutoSuggestBox.ItemContainerStyle>
                </AutoSuggestBox>

                <StackPanel VerticalAlignment="Center" Spacing="12">
                    <Grid Width="68" Height="68" HorizontalAlignment="Center">
                        <PersonPicture
                            Width="68"
                            Height="68"
                            DisplayName="{x:Bind ViewModel.DialContactDisplayName, Mode=OneWay}"
                            ProfilePicture="{x:Bind ViewModel.DialContactAvatar, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.DialContactAvatar, Mode=OneWay, Converter={StaticResource EmptyObjectToVisibilityConverter}}" />
                        <Border
                            Width="68"
                            Height="68"
                            CornerRadius="34"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Visibility="{x:Bind ViewModel.DialContactAvatar, Mode=OneWay, Converter={StaticResource InverseEmptyObjectToVisibilityConverter}}">
                            <FontIcon
                                Glyph="&#xE77B;"
                                FontSize="24"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <TextBlock
                        Text="{x:Bind ViewModel.DialContactDisplayName, Mode=OneWay}"
                        FontSize="18"
                        FontWeight="SemiBold"
                        TextAlignment="Center"
                        HorizontalAlignment="Center"
                        MaxWidth="300"
                        TextTrimming="CharacterEllipsis"
                        Visibility="{x:Bind ViewModel.DialContactDisplayName, Mode=OneWay, Converter={StaticResource StringVisibilityConverter}}" />

                    <TextBlock
                        Text="{x:Bind ViewModel.PhoneNumber, Mode=OneWay}"
                        FontSize="22"
                        FontWeight="SemiBold"
                        TextAlignment="Center"
                        HorizontalAlignment="Center"
                        MinHeight="30"
                        VerticalAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        MaxWidth="300"
                        Visibility="{x:Bind ViewModel.DialContactDisplayName, Mode=OneWay, Converter={StaticResource InverseStringVisibilityConverter}}" />

                    <TextBlock
                        Text="{x:Bind ViewModel.PhoneNumber, Mode=OneWay}"
                        FontSize="14"
                        TextAlignment="Center"
                        HorizontalAlignment="Center"
                        TextTrimming="CharacterEllipsis"
                        MaxWidth="300"
                        Foreground="{ThemeResource TextFillColorSecondary}"
                        Visibility="{x:Bind ViewModel.DialContactDisplayName, Mode=OneWay, Converter={StaticResource StringVisibilityConverter}}" />

                    <Grid ColumnSpacing="10" RowSpacing="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource DialPadKeyStyle}" Content="1"
                            Command="{x:Bind ViewModel.AppendDialKeyCommand}" CommandParameter="1"/>
                        <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource DialPadKeyStyle}" Content="2"
                            Command="{x:Bind ViewModel.AppendDialKeyCommand}" CommandParameter="2"/>
                        <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource DialPadKeyStyle}" Content="3"
                            Command="{x:Bind ViewModel.AppendDialKeyCommand}" CommandParameter="3"/>

                        <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource DialPadKeyStyle}" Content="4"
                            Command="{x:Bind ViewModel.AppendDialKeyCommand}" CommandParameter="4"/>
                        <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource DialPadKeyStyle}" Content="5"
                            Command="{x:Bind ViewModel.AppendDialKeyCommand}" CommandParameter="5"/>
                        <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource DialPadKeyStyle}" Content="6"
                            Command="{x:Bind ViewModel.AppendDialKeyCommand}" CommandParameter="6"/>

                        <Button Grid.Row="2" Grid.Column="0" Style="{StaticResource DialPadKeyStyle}" Content="7"
                            Command="{x:Bind ViewModel.AppendDialKeyCommand}" CommandParameter="7"/>
                        <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource DialPadKeyStyle}" Content="8"
                            Command="{x:Bind ViewModel.AppendDialKeyCommand}" CommandParameter="8"/>
                        <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource DialPadKeyStyle}" Content="9"
                            Command="{x:Bind ViewModel.AppendDialKeyCommand}" CommandParameter="9"/>

                        <Button Grid.Row="3" Grid.Column="0" Style="{StaticResource DialPadKeyStyle}" Content="*"
                                Command="{x:Bind ViewModel.AppendDialKeyCommand}" CommandParameter="*"/>
                        <Button Grid.Row="3" Grid.Column="1" Style="{StaticResource DialPadKeyStyle}"
                                Click="DialZeroButton_Click"
                                Holding="DialZeroButton_Holding"
                                RightTapped="DialZeroButton_RightTapped">
                            <StackPanel Spacing="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="0" HorizontalAlignment="Center" />
                                <TextBlock Text="+" FontSize="12" Opacity="0.75" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Row="3" Grid.Column="2" Style="{StaticResource DialPadKeyStyle}" Content="#"
                                Command="{x:Bind ViewModel.AppendDialKeyCommand}" CommandParameter="#"/>
                    </Grid>

                    <Grid HorizontalAlignment="Center" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="72"/>
                        </Grid.ColumnDefinitions>
                        <Button
                            Grid.Column="1"
                            Click="DialButton_Click"
                            Width="48"
                            Height="48"
                            CornerRadius="24"
                            HorizontalAlignment="Center"
                            IsEnabled="{x:Bind ViewModel.PhoneNumber, Mode=OneWay, Converter={StaticResource EmptyStringToObjectConverter}}">
                            <FontIcon Glyph="&#xE717;" FontSize="20"/>
                        </Button>
                        <RepeatButton
                            Grid.Column="2"
                            Width="48"
                            Height="48"
                            CornerRadius="24"
                            HorizontalAlignment="Center"
                            Delay="400"
                            Click="RepeatBackspaceButton_Click"
                            IsEnabled="{x:Bind ViewModel.PhoneNumber, Mode=OneWay, Converter={StaticResource EmptyStringToObjectConverter}}">
                            <FontIcon Glyph="&#xE94F;" FontSize="16"/>
                        </RepeatButton>
                    </Grid>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
