<Page
    x:Class="Sefirah.Views.DeviceSettings.NotificationSettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Sefirah.UserControls"
    xmlns:converters="using:Sefirah.Converters"
    xmlns:wctconverters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:Sefirah.Helpers"
    xmlns:local="using:Sefirah.Views.DeviceSettings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Sefirah.Data.Models"
    xmlns:wuc="using:CommunityToolkit.WinUI.Controls"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Margin="20" Spacing="16">
            <TextBlock
                FontSize="16"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{helpers:ResourceString Name=NotificationSettings}" />
            <StackPanel Spacing="5">
                <wuc:SettingsCard Description="{helpers:ResourceString Name=DisplayToastNotifications}" Header="{helpers:ResourceString Name=ShowNotificationToast}">
                    <wuc:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE7E7;" />
                    </wuc:SettingsCard.HeaderIcon>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.ShowNotificationToast, Mode=TwoWay}" />
                </wuc:SettingsCard>

                <wuc:SettingsCard Description="{helpers:ResourceString Name=ShowBadgeDescription}" Header="{helpers:ResourceString Name=ShowBadge}">
                    <wuc:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xF136;" />
                    </wuc:SettingsCard.HeaderIcon>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.ShowBadge, Mode=TwoWay}" />
                </wuc:SettingsCard>

                <wuc:SettingsCard Description="{helpers:ResourceString Name=IgnoreWindowsApps}" Header="{helpers:ResourceString Name=IgnoreWindowsApps}">
                    <wuc:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE894;" />
                    </wuc:SettingsCard.HeaderIcon>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.IgnoreWindowsApps, Mode=TwoWay}" />
                </wuc:SettingsCard>

                <wuc:SettingsCard Description="{helpers:ResourceString Name=IgnoreDuringDoNotDisturbDescription}" Header="{helpers:ResourceString Name=IgnoreDuringDoNotDisturb}">
                    <wuc:SettingsCard.HeaderIcon>
                        <FontIcon Glyph="&#xE7ED;" />
                    </wuc:SettingsCard.HeaderIcon>
                    <ToggleSwitch IsOn="{x:Bind ViewModel.IgnoreNotificationDuringDnd, Mode=TwoWay}" />
                </wuc:SettingsCard>

                <wuc:SettingsExpander
                    Header="{helpers:ResourceString Name=AppSpecificSettings}"
                    ItemsSource="{x:Bind ViewModel.FilteredRemoteApps, Mode=OneWay}">

                    <wuc:SettingsExpander.HeaderIcon>
                        <FontIcon Glyph="&#xE7F4;" />
                    </wuc:SettingsExpander.HeaderIcon>

                    <wuc:SettingsExpander.ItemsHeader>
                        <Grid
                            Padding="58,16,44,16"
                            ColumnSpacing="8"
                            Background="{ThemeResource ExpanderHeaderBackground}"
                            BorderBrush="{ThemeResource ExpanderHeaderBorderBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                AutomationProperties.Name="{helpers:ResourceString Name=SearchApps}"
                                PlaceholderText="{helpers:ResourceString Name=SearchApps}"
                                Text="{x:Bind ViewModel.NotificationAppsSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="1">
                                <FontIcon Glyph="&#xEA98;" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem
                                            Click="OnSetAllMenuFlyoutItemClick"
                                            Tag="ToastFeed"
                                            Text="{helpers:ResourceString Name=NotificationFilterToastFeed/Content}" />
                                        <MenuFlyoutItem
                                            Click="OnSetAllMenuFlyoutItemClick"
                                            Tag="Feed"
                                            Text="{helpers:ResourceString Name=NotificationFilterFeed/Content}" />
                                        <MenuFlyoutItem
                                            Click="OnSetAllMenuFlyoutItemClick"
                                            Tag="Disabled"
                                            Text="{helpers:ResourceString Name=NotificationFilterDisabled/Content}" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>
                    </wuc:SettingsExpander.ItemsHeader>
                    <wuc:SettingsExpander.ItemTemplate>
                        <DataTemplate x:DataType="models:ApplicationItem">
                            <wuc:SettingsCard>
                                <wuc:SettingsCard.Header>
                                    <StackPanel Orientation="Horizontal" Spacing="20">
                                        <Image
                                            Width="32"
                                            Height="32"
                                            Source="{x:Bind IconPath}" />
                                        <TextBlock FontSize="16" Text="{x:Bind AppName}" />
                                    </StackPanel>
                                </wuc:SettingsCard.Header>
                                <Button Content="{x:Bind SelectedNotificationFilter, Mode=OneWay}">
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem
                                                Click="OnMenuFlyoutItemClick"
                                                CommandParameter="ToastFeed"
                                                Tag="{x:Bind PackageName}"
                                                Text="{helpers:ResourceString Name=NotificationFilterToastFeed/Content}" />
                                            <MenuFlyoutItem
                                                Click="OnMenuFlyoutItemClick"
                                                CommandParameter="Feed"
                                                Tag="{x:Bind PackageName}"
                                                Text="{helpers:ResourceString Name=NotificationFilterFeed/Content}" />
                                            <MenuFlyoutItem
                                                Click="OnMenuFlyoutItemClick"
                                                CommandParameter="Disabled"
                                                Tag="{x:Bind PackageName}"
                                                Text="{helpers:ResourceString Name=NotificationFilterDisabled/Content}" />
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </wuc:SettingsCard>
                        </DataTemplate>
                    </wuc:SettingsExpander.ItemTemplate>
                    <wuc:SettingsExpander.Items />
                </wuc:SettingsExpander>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
