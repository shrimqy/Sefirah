<Page
    x:Class="Sefirah.Views.Settings.DevicesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Sefirah.UserControls"
    xmlns:converters="using:Sefirah.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dbModel="using:Sefirah.Data.AppDatabase.Models"
    xmlns:helpers="using:Sefirah.Helpers"
    xmlns:local="using:Sefirah.Views.Settings"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Sefirah.Data.Models"
    xmlns:vm="using:Sefirah.ViewModels.Settings"
    x:Name="DevicePage"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <converters:StringNullOrEmptyToBooleanConverter x:Key="StringNullOrEmptyToBooleanConverter" />
        <converters:DateTimeDevicesConverter x:Key="DateTimeDevicesConverter" />
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:StringEqualsConverter x:Key="StringEqualsConverter" />
        <converters:CountToVisibilityConverter x:Key="CountToVisibilityConverter" />
        <converters:NullToOpacityConverter x:Key="NullToOpacityConverter" />
        <converters:NullBooleanConverter x:Key="NullBooleanConverter" />
    </Page.Resources>

    <Page.DataContext>
        <vm:DevicesViewModel x:Name="ViewModel" />
    </Page.DataContext>

    <ScrollViewer>
        <StackPanel Spacing="10">
            <!--  Paired Devices Section  -->
            <TextBlock
                Margin="0,0,0,8"
                FontSize="24"
                FontWeight="SemiBold"
                Text="{helpers:ResourceString Name=PairedDevices/Title}"
                Visibility="{x:Bind ViewModel.PairedDevices.Count, Mode=OneWay, Converter={StaticResource CountToVisibilityConverter}}" />

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.PairedDevices, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:PairedDevice">
                        <controls:SettingsBlockControl
                            Title="{x:Bind Name}"
                            Description="{x:Bind ConnectionButtonText, Converter={StaticResource DateTimeDevicesConverter}}"
                            IsClickable="False">
                            <controls:SettingsBlockControl.Icon>
                                <Grid Width="30" Height="53">
                                    <Rectangle
                                        Opacity="0.5"
                                        RadiusX="4"
                                        RadiusY="4"
                                        Stroke="Black"
                                        StrokeThickness="2">
                                        <Rectangle.Fill>
                                            <SolidColorBrush Opacity="0.1" Color="{ThemeResource SystemBaseLowColor}" />
                                        </Rectangle.Fill>
                                    </Rectangle>
                                    <Rectangle
                                        Margin="2"
                                        RadiusX="4"
                                        RadiusY="4"
                                        Stroke="Black"
                                        StrokeThickness="1" />
                                    <Border Margin="3" CornerRadius="4">
                                        <Border.Background>
                                            <LinearGradientBrush Opacity="{x:Bind Wallpaper, Converter={StaticResource NullToOpacityConverter}, Mode=OneWay}" StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="#FF0070FF" />
                                                <GradientStop Offset="1" Color="#FF2E90FF" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Image
                                            x:Name="WallpaperImage"
                                            x:Load="{x:Bind Wallpaper, Converter={StaticResource NullBooleanConverter}, Mode=OneWay}"
                                            Source="{x:Bind Wallpaper, Mode=OneWay}"
                                            Stretch="UniformToFill" />
                                    </Border>
                                </Grid>
                            </controls:SettingsBlockControl.Icon>
                            <controls:SettingsBlockControl.SettingsActionableElement>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Command="{Binding DataContext.OpenDeviceSettingsCommand, ElementName=DevicePage}" CommandParameter="{x:Bind}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontSize="14" Glyph="&#xE713;" />
                                            <TextBlock Text="Settings" />
                                        </StackPanel>
                                    </Button>
                                    <Button
                                        VerticalAlignment="Stretch"
                                        Command="{Binding DataContext.RemoveDeviceCommand, ElementName=DevicePage}"
                                        CommandParameter="{x:Bind}">
                                        <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                    </Button>
                                </StackPanel>
                            </controls:SettingsBlockControl.SettingsActionableElement>
                        </controls:SettingsBlockControl>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!--  Discovered Devices Section  -->
            <TextBlock
                Margin="0,0,0,8"
                FontSize="24"
                FontWeight="SemiBold"
                Text="{helpers:ResourceString Name=AvailableDevices/Title}" />
            <TextBlock
                FontSize="14"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{helpers:ResourceString Name=AvailableDevices/Subtitle}"
                TextWrapping="Wrap" />

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.DiscoveredDevices, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Vertical" Spacing="8" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:DiscoveredDevice">
                        <controls:SettingsBlockControl
                            Title="{x:Bind DeviceName}"
                            Description="{x:Bind FormattedKey}"
                            IsClickable="False">
                            <controls:SettingsBlockControl.Icon>
                                <FontIcon Glyph="&#xE8EA;" />
                            </controls:SettingsBlockControl.Icon>
                        </controls:SettingsBlockControl>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </ScrollViewer>
</Page>
